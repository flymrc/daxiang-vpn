node:
  name: jp-android-01

hub:
  endpoint: 36.50.84.68:51820
  public_key: HUB_PUBLIC_KEY_HERE

wireguard:
  # embedded: dxandroid-egress/sing-box creates the WireGuard endpoint.
  # external: WireGuard App/kernel owns the tunnel; dxandroid-egress only runs the proxy.
  mode: external
  address: 10.66.0.101/24
  private_key: ANDROID_WG_PRIVATE_KEY_HERE
  mtu: 1280
  workers: 0

proxy:
  listen_port: 1080
