server:
  # Public UDP listener for Android reverse clients.
  listen: 0.0.0.0:39093
  # Hub-side HTTP CONNECT proxy exposed on the WireGuard address for clients.
  proxy: 10.66.0.1:18081
  # Store the real token in this file, mode 600. Do not commit it.
  token_file: /etc/daxiang/dxreverse/token
  transport: tcp
  # Used when transport is quic; harmless to keep for TCP rollback safety.
  tls_cert_file: /etc/daxiang/dxreverse/server.crt
  tls_key_file: /etc/daxiang/dxreverse/server.key
  # server = Hub resolves target hostnames before sending IP:port to Android.
  # client = Android resolves target hostnames and can use its mobile IPv6 path.
  resolve: client
  # Limit who can use the Hub-side proxy. Narrow these to issued client /32s in production.
  allowed_proxy_cidrs:
    - 10.66.0.0/24
  # Protect the Android mobile egress from client-side burst concurrency.
  # Excess CONNECT requests fail fast with HTTP 429 instead of piling up in the tunnel.
  max_proxy_connections: 32
  max_proxy_connections_per_client: 12
  # Diagnostic /fetch endpoint is disabled unless explicitly enabled.
  enable_fetch: false
