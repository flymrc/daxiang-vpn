{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "纵横 VPN",
  "mainBinaryName": "zhvpn-desktop",
  "version": "0.4.4",
  "identifier": "com.zongheng.vpn",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "纵横 VPN",
        "width": 420,
        "height": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "externalBin": ["binaries/zhvpn"],
    "publisher": "纵横 VPN",
    "copyright": "© 2026 纵横 VPN",
    "category": "Utility",
    "shortDescription": "纵横 VPN 桌面客户端",
    "longDescription": "纵横 VPN 桌面客户端：一键连接日本住宅出口，自动配置系统代理。",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": { "type": "downloadBootstrapper" },
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
