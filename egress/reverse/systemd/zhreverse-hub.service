[Unit]
Description=Zongheng Android reverse egress hub
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
Group=root
ExecStart=/opt/zongheng/zhreverse/zhreverse server --config /etc/zongheng/zhreverse/server.yaml
Restart=always
RestartSec=3
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true
ReadWritePaths=/var/log/zongheng /etc/zongheng/zhreverse

[Install]
WantedBy=multi-user.target
