{
  "name": "zhhub-admin-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "generate:api": "openapi-typescript ../openapi.yml -o src/lib/openapi.d.ts",
    "dev": "vite dev",
    "check": "npm run generate:api && svelte-check --tsconfig ./tsconfig.json",
    "build": "npm run generate:api && vite build",
    "build:embed": "npm run build"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.1.1",
    "autoprefixer": "^10.4.21",
    "openapi-typescript": "^7.10.1",
    "postcss": "^8.5.6",
    "svelte": "^5.56.3",
    "svelte-check": "^4.6.0",
    "tailwindcss": "^3.4.18",
    "typescript": "~5.9.2",
    "vite": "^6.4.3"
  }
}
